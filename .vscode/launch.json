{
    // https://code.visualstudio.com/docs/editor/debugging
    // Shell redirects (e.g. > catalog.json) are not applied here—args go straight to Python.
    // After debug, redirect in the integrated terminal if you need files on disk.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "tap-qbwc discover",
            "type": "python",
            "request": "launch",
            "program": "../tap_qbwc/tap.py",
            "cwd": "${workspaceFolder}/.secrets",
            "args": [
                "--config",
                "config.json",
                "--discover",
                ">",
                "catalog.json"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python3"
        },
        {
            "name": "tap-qbwc get",
            "type": "python",
            "request": "launch",
            "justMyCode": false,
            "program": "../tap_qbwc/tap.py",
            "cwd": "${workspaceFolder}/.secrets",
            "args": [
                "--config",
                "config.json",
                "--state",
                "state.json",
                "--catalog",
                "catalog-selected.json",
                ">",
                "data.txt"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python3"
        }
    ]
}
